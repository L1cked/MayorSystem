---
import '../styles/site.css';
import project from '../data/project.json';
import release from '../data/generated-release.json';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const image = (name: string) => `${base}images/${name}`;
const absoluteImage = (name: string) => new URL(`images/${name}`, project.website).toString();
const docsUrl = project.deepWiki;
const addonDocsUrl = project.deepWikiAddonApi;
const downloadsUrl = new URL('downloads/', project.website).toString();
const pageDescription =
  'Download MayorSystem for Paper 1.21+, open the DeepWiki docs, or get the Maven Central addon API jar for addon development.';
const externalLinkAttrs = (href: string) =>
  href.startsWith('http') && !href.startsWith(project.website)
    ? { target: '_blank', rel: 'noopener noreferrer' }
    : {};

const pages = [
  ['Overview', base],
  ['Downloads', `${base}downloads/`],
  ['Docs', docsUrl],
  ['Addon API', addonDocsUrl],
];

const links = [
  ['Plugin jar', release.pluginJarUrl, `MayorSystem ${release.version} for ${project.minecraft}.`],
  ['Docs', docsUrl, 'Setup, commands, configuration, permissions, and integration notes.'],
  ['Addon API jar', release.apiJarUrl, 'CompileOnly artifact for addon developers.'],
  ['Addon docs', addonDocsUrl, 'Public API usage and external perk source examples.'],
  ['SystemSellAddon', project.systemSellAddon, 'Economy perk addon source on GitHub.'],
  ['SystemSkyblockStyleAddon', project.systemSkyblockStyleAddon, 'Skyblock-style perk addon source on GitHub.'],
  ['Discord support', project.discord, 'Community support and plugin update discussion.'],
  ['Spigot page', project.spigot, 'Public resource page for server owners.'],
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Download MayorSystem',
  description: pageDescription,
  url: downloadsUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: 'MayorSystem',
    url: project.website,
  },
  about: {
    '@type': 'SoftwareApplication',
    name: project.name,
    applicationCategory: 'GameApplication',
    operatingSystem: 'Paper Minecraft Server',
    softwareVersion: release.version,
    downloadUrl: release.pluginJarUrl,
    codeRepository: project.repository,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Download MayorSystem - Paper Minecraft Plugin</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow" />
    <meta name="google-site-verification" content="hVLFgdtb8ntBvde5K467IpIjYmXApa3HB6VywDLyd9I" />
    <link rel="canonical" href={downloadsUrl} />
    <link rel="alternate" type="text/plain" title="MayorSystem llms.txt" href={new URL('llms.txt', project.website).toString()} />
    <meta property="og:title" content="Download MayorSystem - Paper Minecraft Plugin" />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={absoluteImage('banner.png')} />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="320" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={downloadsUrl} />
    <meta property="og:site_name" content="MayorSystem" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Download MayorSystem - Paper Minecraft Plugin" />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={absoluteImage('banner.png')} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <link rel="icon" href={image('logo-site.png')} />
  </head>
  <body>
    <div class="site-frame">
      <aside class="side-rail" aria-label="Site navigation">
        <a class="brand" href={base}>
          <img src={image('logo-site.png')} alt="" width="34" height="34" />
          <span>
            <strong>MayorSystem</strong>
            <span>Downloads</span>
          </span>
        </a>

        <nav class="rail-links">
          <span>Pages</span>
          {pages.map(([label, href]) => (
            <a href={href} {...externalLinkAttrs(href)}>{label}</a>
          ))}
        </nav>
      </aside>

      <div class="page-pane">
        <header class="topbar">
          <span>Current release: {release.version}</span>
          <nav aria-label="Primary navigation">
            <a href={docsUrl} {...externalLinkAttrs(docsUrl)}>Docs</a>
            <a href={project.discord} {...externalLinkAttrs(project.discord)}>Discord</a>
            <a href={project.spigot} {...externalLinkAttrs(project.spigot)}>Spigot</a>
            <a href={project.repository} {...externalLinkAttrs(project.repository)}>GitHub</a>
          </nav>
        </header>

        <main>
          <section class="download-hero">
            <p class="eyebrow">Current release</p>
            <h1>Download MayorSystem.</h1>
            <p>{release.version} for {project.minecraft}. Server owners need the plugin jar. Addon developers use the API jar.</p>
            <div class="hero-actions">
              <a class="button button-primary" href={release.pluginJarUrl} {...externalLinkAttrs(release.pluginJarUrl)}>Download plugin</a>
              <a class="button" href={docsUrl} {...externalLinkAttrs(docsUrl)}>Open docs</a>
              <a class="button" href={project.discord} {...externalLinkAttrs(project.discord)}>Join Discord</a>
            </div>
          </section>

          <section class="path-section" aria-labelledby="download-links-title">
            <div class="section-kicker">
              <h2 id="download-links-title">Files and links.</h2>
              <p>Pick the artifact or reference that matches your setup.</p>
            </div>
            <div class="path-list path-list-wide">
              {links.map(([label, href, body]) => (
                <a href={href} {...externalLinkAttrs(href)}>
                  <strong>{label}</strong>
                  <span>{body}</span>
                </a>
              ))}
            </div>
          </section>
        </main>

        <footer class="footer">
          <a href={base}>Home</a>
          <a href={docsUrl} {...externalLinkAttrs(docsUrl)}>Docs</a>
          <a href={project.discord} {...externalLinkAttrs(project.discord)}>Discord</a>
          <a href={project.repository} {...externalLinkAttrs(project.repository)}>Source</a>
        </footer>
      </div>
    </div>
  </body>
</html>

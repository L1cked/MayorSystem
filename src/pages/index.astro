---
import '../styles/site.css';
import project from '../data/project.json';
import release from '../data/generated-release.json';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const image = (name: string) => `${base}images/${name}`;
const absoluteImage = (name: string) => new URL(`images/${name}`, project.website).toString();
const downloadsUrl = `${base}downloads/`;
const docsUrl = project.deepWiki;
const addonDocsUrl = project.deepWikiAddonApi;
const pageDescription =
  'MayorSystem is a Paper 1.21+ Minecraft mayor election plugin with scheduled terms, voting, perks, displays, admin tools, and addon support.';
const externalLinkAttrs = (href: string) =>
  href.startsWith('http') && !href.startsWith(project.website)
    ? { target: '_blank', rel: 'noopener noreferrer' }
    : {};

const pages = [
  ['Overview', base],
  ['Downloads', downloadsUrl],
  ['Docs', docsUrl],
  ['Addon API', addonDocsUrl],
];

const paths = [
  ['Install', downloadsUrl, 'Download the server jar and verify requirements.'],
  ['Operate', docsUrl, 'Use DeepWiki for commands, config, permissions, and integrations.'],
  ['Extend', addonDocsUrl, 'Build addons with snapshots, events, and external perk sources.'],
];

const addons = [
  ['SystemSellAddon', project.systemSellAddon, 'Economy perk hooks for servers using SystemSell.'],
  ['SystemSkyblockStyleAddon', project.systemSkyblockStyleAddon, 'Skyblock-style perk hooks for MayorSystem.'],
];

const features = [
  ['Server elections', 'Run scheduled mayor terms, candidate applications, voting, and admin election controls.'],
  ['Mayor perks', 'Let elected mayors choose configured server-wide perks, custom requests, and addon perks.'],
  ['Drop-in integrations', 'Auto-detect Vault, LuckPerms, PlaceholderAPI, NPCs, holograms, and MayorSystem addons.'],
];

const screenshots = [
  ['Main menu', 'main-menu.png', 'MayorSystem main menu showing election actions', 783, 458],
  ['Vote menu', 'vote-menu.png', 'MayorSystem vote menu showing candidate choices', 829, 473],
  ['Mayor card', 'mayor-card.png', 'Mayor profile card with current mayor details', 870, 441],
  ['Mayor NPC', 'mayor-npc.png', 'Mayor NPC display in game', 1009, 779],
  ['Leaderboard hologram', 'leaderboard-hologram.png', 'Leaderboard hologram display', 1101, 567],
  ['Candidate menu', 'candidate-menu.png', 'Candidate management menu', 773, 400],
  ['Perk catalog', 'perk-catalog.png', 'Perk catalog menu', 663, 436],
  ['Admin menu', 'admin-menu.png', 'Admin menu for MayorSystem management', 782, 426],
  ['Election settings', 'election-settings.png', 'Election settings menu', 749, 447],
  ['Audit log', 'audit-log.png', 'Audit log menu', 871, 520],
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: project.name,
  applicationCategory: 'GameApplication',
  operatingSystem: 'Paper Minecraft Server',
  softwareVersion: release.version,
  description: pageDescription,
  url: project.website,
  image: absoluteImage('banner.png'),
  downloadUrl: release.pluginJarUrl,
  codeRepository: project.repository,
  programmingLanguage: 'Kotlin',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>MayorSystem - Paper Minecraft Election Plugin</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow" />
    <meta name="google-site-verification" content="hVLFgdtb8ntBvde5K467IpIjYmXApa3HB6VywDLyd9I" />
    <link rel="canonical" href={project.website} />
    <link rel="sitemap" type="application/xml" href={new URL('sitemap-index.xml', project.website).toString()} />
    <link rel="alternate" type="text/plain" title="MayorSystem llms.txt" href={new URL('llms.txt', project.website).toString()} />
    <meta property="og:title" content="MayorSystem - Paper Minecraft Election Plugin" />
    <meta property="og:description" content="Add elections, mayors, perks, displays, admin tools, and addon support to Paper servers." />
    <meta property="og:image" content={absoluteImage('banner.png')} />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="320" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={project.website} />
    <meta property="og:site_name" content="MayorSystem" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="MayorSystem - Paper Minecraft Election Plugin" />
    <meta name="twitter:description" content="Add elections, mayors, perks, displays, admin tools, and addon support to Paper servers." />
    <meta name="twitter:image" content={absoluteImage('banner.png')} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <link rel="icon" href={image('logo-site.png')} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="site-frame">
      <aside class="side-rail" aria-label="Site navigation">
        <a class="brand" href={base} aria-label="MayorSystem home">
          <img src={image('logo-site.png')} alt="" width="34" height="34" />
          <span>
            <strong>MayorSystem</strong>
            <span>{project.minecraft}</span>
          </span>
        </a>

        <nav class="rail-links">
          <span>Pages</span>
          {pages.map(([label, href]) => (
            <a href={href} {...externalLinkAttrs(href)}>{label}</a>
          ))}
        </nav>
      </aside>

      <div class="page-pane">
        <header class="topbar">
          <span>Last release: {release.version}</span>
          <nav aria-label="Primary navigation">
            <a href={docsUrl} {...externalLinkAttrs(docsUrl)}>Docs</a>
            <a href={project.discord} {...externalLinkAttrs(project.discord)}>Discord</a>
            <a href={project.spigot} {...externalLinkAttrs(project.spigot)}>Spigot</a>
            <a href={project.repository} {...externalLinkAttrs(project.repository)}>GitHub</a>
          </nav>
        </header>

        <main id="content">
          <section class="hero">
            <div class="hero-copy-block">
              <p class="eyebrow">Paper election plugin</p>
              <h1>Mayors, elections, and perks for community servers.</h1>
              <p class="hero-copy">
                A fully customizable MayorSystem setup for scheduled terms, player voting, mayor perks, admin tools, displays, and addon development.
              </p>
              <div class="hero-actions">
                <a class="button button-primary" href={downloadsUrl}>Download {release.version}</a>
                <a class="button" href={docsUrl} {...externalLinkAttrs(docsUrl)}>Open docs</a>
                <a class="button" href={project.discord} {...externalLinkAttrs(project.discord)}>Join Discord</a>
              </div>
            </div>

            <section class="carousel" aria-label="MayorSystem screenshots">
              <div class="carousel-viewport">
                {screenshots.map(([label, file, alt, width, height], index) => (
                  <figure class={`carousel-slide${index === 0 ? ' is-active' : ''}`} data-slide>
                    <img src={image(file)} alt={alt} width={width} height={height} loading={index === 0 ? 'eager' : 'lazy'} />
                    <figcaption>{label}</figcaption>
                  </figure>
                ))}
              </div>
              <div class="carousel-controls">
                <button type="button" data-carousel-prev aria-label="Previous screenshot">Prev</button>
                <div class="carousel-dots" aria-label="Screenshot selector">
                  {screenshots.map(([label], index) => (
                    <button
                      type="button"
                      class={index === 0 ? 'is-active' : ''}
                      data-carousel-dot={index}
                      aria-label={`Show ${label}`}
                    ></button>
                  ))}
                </div>
                <button type="button" data-carousel-next aria-label="Next screenshot">Next</button>
              </div>
            </section>
          </section>

          <section class="feature-section" aria-labelledby="feature-title">
            <div class="section-kicker">
              <h2 id="feature-title">A Minecraft mayor plugin built for live Paper servers.</h2>
              <p>Configured in game first, backed by safe config files when you need deeper control.</p>
            </div>
            <div class="feature-list">
              {features.map(([label, body]) => (
                <article>
                  <strong>{label}</strong>
                  <span>{body}</span>
                </article>
              ))}
            </div>
          </section>

          <section class="path-section" aria-labelledby="paths-title">
            <div class="section-kicker">
              <h2 id="paths-title">Start with the right path.</h2>
              <p>{project.java}. Optional integrations stay optional.</p>
            </div>
            <div class="path-list">
              {paths.map(([label, href, body]) => (
                <a href={href} {...externalLinkAttrs(href)}>
                  <strong>{label}</strong>
                  <span>{body}</span>
                </a>
              ))}
            </div>
          </section>

          <section class="addon-section" aria-labelledby="addons-title">
            <div class="section-kicker">
              <h2 id="addons-title">Official addons.</h2>
              <p>Extra perk sources built for the new MayorSystem addon API.</p>
            </div>
            <div class="addon-links">
              {addons.map(([label, href, body]) => (
                <a href={href} {...externalLinkAttrs(href)}>
                  <strong>{label}</strong>
                  <span>{body}</span>
                </a>
              ))}
            </div>
          </section>
        </main>

        <footer class="footer">
          <span>MayorSystem is not an official Minecraft product.</span>
          <a href={project.discord} {...externalLinkAttrs(project.discord)}>Discord</a>
          <a href={project.repository} {...externalLinkAttrs(project.repository)}>Source</a>
        </footer>
      </div>
    </div>

    <script>
      const slides = [...document.querySelectorAll('[data-slide]')];
      const dots = [...document.querySelectorAll('[data-carousel-dot]')];
      const prev = document.querySelector('[data-carousel-prev]');
      const next = document.querySelector('[data-carousel-next]');
      let active = 0;

      function showSlide(index) {
        active = (index + slides.length) % slides.length;
        slides.forEach((slide, slideIndex) => {
          slide.classList.toggle('is-active', slideIndex === active);
        });
        dots.forEach((dot, dotIndex) => {
          dot.classList.toggle('is-active', dotIndex === active);
        });
      }

      prev?.addEventListener('click', () => showSlide(active - 1));
      next?.addEventListener('click', () => showSlide(active + 1));
      dots.forEach((dot, index) => dot.addEventListener('click', () => showSlide(index)));
    </script>
  </body>
</html>
